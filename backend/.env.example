# OpenRouter (server-side only — never expose keys to the browser)
OPENROUTER_API_KEY=
# Default matches project default; override to switch models
OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# Optional OpenRouter attribution (https://openrouter.ai/docs)
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_APP_NAME=VITALIS AI

# CORS: comma-separated origins, or * for dev
ALLOWED_ORIGINS=*
