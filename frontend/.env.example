# VITALIS AI Platform - Environment Configuration
# Copy this to .env.local and adjust values for your environment.

# FastAPI backend origin (OpenRouter key is server-side only — never put it here)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional label shown next to "Model" in the triage section (defaults to OpenRouter)
NEXT_PUBLIC_AI_MODEL_LABEL=OpenRouter

# Medical Database Synchronization
NEXT_PUBLIC_DB_SYNC_INTERVAL=300000

# System Integrity
NEXT_PUBLIC_DEBUG_MODE=false
